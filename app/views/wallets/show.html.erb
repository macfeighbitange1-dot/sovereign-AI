<div class="p-6 md:p-12 max-w-6xl mx-auto space-y-12">
  
  <div class="relative overflow-hidden rounded-3xl bg-neutral p-10 border border-white/5 shadow-2xl">
    <div class="relative z-10 flex flex-col md:flex-row justify-between items-start md:items-center gap-8">
      <div>
        <h2 class="text-xs uppercase tracking-[0.4em] text-primary font-bold mb-4">Total Liquidity Position</h2>
        <div class="flex items-baseline gap-4">
          <span class="text-6xl md:text-8xl font-black text-white tracking-tighter">
            <%= number_with_delimiter(@balance) %>
          </span>
          <span class="text-3xl font-light text-primary/60">KES</span>
        </div>
      </div>
      
      <div class="flex flex-col gap-2 bg-black/40 p-6 rounded-2xl border border-white/5 backdrop-blur-md">
        <div class="text-[10px] uppercase tracking-widest text-white/40">AI Risk Intelligence</div>
        <div class="flex items-center gap-3">
          <div class="w-3 h-3 rounded-full bg-success animate-pulse shadow-[0_0_15px_rgba(0,255,0,0.5)]"></div>
          <span class="text-lg font-bold text-success italic uppercase tracking-tighter">Healthy Accumulation</span>
        </div>
        <div class="text-[10px] font-mono text-white/20 mt-2">Node: Nairobi_Vault_01</div>
      </div>
    </div>
    <div class="absolute -bottom-20 -left-20 w-80 h-80 bg-primary/10 blur-[120px] rounded-full"></div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    
    <div class="lg:col-span-1 space-y-6">
      <div class="card bg-base-100 border border-white/5 shadow-xl hover:border-primary/30 transition-all duration-500">
        <div class="card-body">
          <h3 class="text-xs font-black uppercase tracking-widest text-primary mb-4 flex items-center gap-2">
            <span class="w-1.5 h-1.5 rounded-full bg-primary"></span> Inbound Capital
          </h3>
          <%= form_with url: deposit_wallet_path(params[:id]), method: :post, class: "space-y-4" do |f| %>
            <div class="form-control">
              <%= f.number_field :amount, placeholder: "Amount in KES", class: "input input-bordered w-full bg-black/30 border-white/10 focus:border-primary text-xl font-bold", required: true %>
            </div>
            <%= f.submit "Initialize Ingress", class: "btn btn-primary w-full shadow-lg shadow-primary/20 font-black uppercase tracking-widest" %>
          <% end %>
        </div>
      </div>

      <div class="card bg-base-100 border border-white/5 shadow-xl hover:border-error/30 transition-all duration-500">
        <div class="card-body">
          <h3 class="text-xs font-black uppercase tracking-widest text-error mb-4 flex items-center gap-2">
            <span class="w-1.5 h-1.5 rounded-full bg-error"></span> Outbound Egress
          </h3>
          <%= form_with url: withdraw_wallet_path(params[:id]), method: :post, class: "space-y-4" do |f| %>
            <div class="form-control">
              <%= f.number_field :amount, placeholder: "Amount in KES", class: "input input-bordered w-full bg-black/30 border-white/10 focus:border-error text-xl font-bold", required: true %>
            </div>
            <%= f.submit "Authorize Egress", class: "btn btn-outline btn-error w-full font-black uppercase tracking-widest" %>
          <% end %>
        </div>
      </div>
    </div>

    <div class="lg:col-span-2">
      <div class="card bg-base-100 border border-white/5 shadow-2xl overflow-hidden">
        <div class="p-8 border-b border-white/5 flex justify-between items-center bg-white/5">
          <h3 class="text-xs font-black uppercase tracking-[0.2em]">Immutable Audit Trail</h3>
          <span class="font-mono text-[9px] text-white/30">STREAM: WALLET_<%= params[:id] %></span>
        </div>
        
        <div class="overflow-x-auto">
          <table class="table table-lg w-full">
            <thead>
              <tr class="text-white/40 text-[10px] uppercase tracking-widest border-b border-white/5">
                <th class="bg-transparent">Event Vector</th>
                <th class="bg-transparent text-right">Magnitude</th>
                <th class="bg-transparent">Temporal Marker</th>
                <th class="bg-transparent">Sequence Hash</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-white/5">
              <% @history.each do |tx| %>
                <tr class="hover:bg-white/[0.02] transition-colors group">
                  <td>
                    <div class="flex items-center gap-3">
                      <div class="w-1.5 h-1.5 rounded-full <%= tx[:event_type] == 'MoneyDeposited' ? 'bg-primary shadow-[0_0_8px_rgba(var(--p))]' : 'bg-error' %>"></div>
                      <span class="text-[11px] font-black tracking-widest uppercase <%= tx[:event_type] == 'MoneyDeposited' ? 'text-primary' : 'text-error' %>">
                        <%= tx[:event_type].gsub('Money', '') %>
                      </span>
                    </div>
                  </td>
                  <td class="text-right font-mono font-bold text-white text-lg">
                    <%= tx[:event_type] == 'MoneyDeposited' ? '+' : '-' %> <%= number_with_delimiter(tx[:amount]) %>
                  </td>
                  <td class="text-[11px] font-medium text-white/50">
                    <%= tx[:timestamp].to_time.in_time_zone('Nairobi').strftime("%H:%M:%S | %d %b %Y") %>
                  </td>
                  <td class="text-[10px] font-mono text-white/10 group-hover:text-white/30 transition-colors">
                    <%= tx[:event_id].first(12) %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>
